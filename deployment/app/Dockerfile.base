FROM python:3.11.4-alpine3.17

RUN adduser -h /ygag -D ygag

WORKDIR /ygag

RUN mkdir logs
RUN chown -R ygag /ygag

ENV PATH "$PATH:/ygag/.local/bin"

# Install runtime dependencies directly from apk repositories
RUN apk update && \
    apk add --no-cache libpq libjpeg-turbo zlib libffi netcat-openbsd && \
    pip3.11 install --no-cache-dir --upgrade pip==24.0